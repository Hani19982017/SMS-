# ===== قاعدة البيانات (PostgreSQL على Render) =====
DATABASE_URL="postgresql://user:pass@host:5432/dbname"

# ===== المصادقة (NextAuth) =====
# ولّد سرًّا عشوائيًا: openssl rand -base64 32
NEXTAUTH_SECRET="ضع_سرًّا_عشوائيًا_هنا"
NEXTAUTH_URL="https://your-app.onrender.com"

# ===== WhatsApp Cloud API (من Meta) =====
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_BUSINESS_ACCOUNT_ID=""
WHATSAPP_WEBHOOK_VERIFY_TOKEN="اختر_رمزًا_سريًّا_للتحقق"

# ===== الذكاء الاصطناعي =====
AI_PROVIDER="openai"          # openai أو claude
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-4-20250514"

# ===== مُرسِل الحملات (Render Cron) =====
CRON_SECRET="سرّ_عشوائي_لحماية_مسار_الإرسال"

# ===== الحساب الافتراضي (للـ seed) =====
ADMIN_EMAIL="admin@aqar.local"
ADMIN_PASSWORD="Admin@12345"
